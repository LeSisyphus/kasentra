  "fixed_sql": [
    {
      "name": "businesses",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"businesses\" (\"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"owner_name\" TEXT NOT NULL, \"phone\" TEXT NULL, \"address\" TEXT NULL, \"business_type\" TEXT NOT NULL DEFAULT 'Toko Sembako', \"created_at\" INTEGER NOT NULL, \"updated_at\" INTEGER NOT NULL, \"synced_at\" INTEGER NULL, PRIMARY KEY (\"id\"), CHECK (length(trim(name)) > 0), CHECK (length(trim(owner_name)) > 0), CHECK (length(trim(business_type)) > 0));"
        }
      ]
    },
    {
      "name": "categories",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"categories\" (\"id\" TEXT NOT NULL, \"business_id\" TEXT NOT NULL REFERENCES businesses (id) ON DELETE RESTRICT, \"type\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"is_default\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_default\" IN (0, 1)), \"created_at\" INTEGER NOT NULL, \"updated_at\" INTEGER NOT NULL, \"synced_at\" INTEGER NULL, PRIMARY KEY (\"id\"), CHECK (type IN ('product', 'expense')), CHECK (length(trim(name)) > 0), UNIQUE (business_id, type, name));"
        }
      ]
    },
    {
      "name": "products",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"products\" (\"id\" TEXT NOT NULL, \"business_id\" TEXT NOT NULL REFERENCES businesses (id) ON DELETE RESTRICT, \"category_id\" TEXT NOT NULL REFERENCES categories (id) ON DELETE RESTRICT, \"name\" TEXT NOT NULL, \"selling_price\" INTEGER NOT NULL, \"cost_price\" INTEGER NULL, \"stock\" INTEGER NULL, \"is_active\" INTEGER NOT NULL DEFAULT 1 CHECK (\"is_active\" IN (0, 1)), \"created_at\" INTEGER NOT NULL, \"updated_at\" INTEGER NOT NULL, \"synced_at\" INTEGER NULL, PRIMARY KEY (\"id\"), CHECK (length(trim(name)) > 0), CHECK (selling_price >= 0), CHECK (cost_price IS NULL OR cost_price >= 0), CHECK (stock IS NULL OR stock >= 0));"
        }
      ]
    },
    {
      "name": "transactions",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"transactions\" (\"id\" TEXT NOT NULL, \"business_id\" TEXT NOT NULL REFERENCES businesses (id) ON DELETE RESTRICT, \"type\" TEXT NOT NULL, \"title\" TEXT NULL, \"category_id\" TEXT NULL REFERENCES categories (id) ON DELETE RESTRICT, \"total_amount\" INTEGER NOT NULL, \"cost_amount\" INTEGER NOT NULL DEFAULT 0, \"profit_amount\" INTEGER NOT NULL DEFAULT 0, \"payment_status\" TEXT NOT NULL DEFAULT 'paid', \"contact_name\" TEXT NULL, \"contact_phone\" TEXT NULL, \"transaction_date\" INTEGER NOT NULL, \"note\" TEXT NULL, \"created_at\" INTEGER NOT NULL, \"updated_at\" INTEGER NOT NULL, \"synced_at\" INTEGER NULL, PRIMARY KEY (\"id\"), CHECK (type IN ('sale', 'expense')), CHECK (payment_status IN ('paid', 'unpaid')), CHECK (total_amount > 0), CHECK (cost_amount >= 0),         CHECK (\n          type != 'expense'\n          OR (\n            title IS NOT NULL\n            AND length(trim(title)) > 0\n          )\n        )\n        ,         CHECK (\n          type != 'expense'\n          OR category_id IS NOT NULL\n        )\n        ,         CHECK (\n          type != 'expense'\n          OR payment_status = 'paid'\n        )\n        ,         CHECK (\n          payment_status != 'unpaid'\n          OR (\n            type = 'sale'\n            AND contact_name IS NOT NULL\n            AND length(trim(contact_name)) > 0\n          )\n        )\n        );"
        }
      ]
    },
    {
      "name": "transaction_items",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"transaction_items\" (\"id\" TEXT NOT NULL, \"transaction_id\" TEXT NOT NULL REFERENCES transactions (id) ON DELETE CASCADE, \"product_id\" TEXT NULL REFERENCES products (id) ON DELETE SET NULL, \"item_name\" TEXT NOT NULL, \"quantity\" INTEGER NOT NULL, \"selling_price\" INTEGER NOT NULL, \"cost_price\" INTEGER NULL, \"subtotal\" INTEGER NOT NULL, PRIMARY KEY (\"id\"), CHECK (length(trim(item_name)) > 0), CHECK (quantity > 0), CHECK (selling_price >= 0), CHECK (cost_price IS NULL OR cost_price >= 0), CHECK (subtotal >= 0), CHECK (subtotal = quantity * selling_price));"
        }
      ]
    },
    {
      "name": "debts",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"debts\" (\"id\" TEXT NOT NULL, \"business_id\" TEXT NOT NULL REFERENCES businesses (id) ON DELETE RESTRICT, \"source_transaction_id\" TEXT NULL REFERENCES transactions (id) ON DELETE SET NULL, \"type\" TEXT NOT NULL, \"contact_name\" TEXT NOT NULL, \"contact_phone\" TEXT NULL, \"amount\" INTEGER NOT NULL, \"remaining_amount\" INTEGER NOT NULL, \"status\" TEXT NOT NULL DEFAULT 'unpaid', \"debt_date\" INTEGER NOT NULL, \"note\" TEXT NULL, \"created_at\" INTEGER NOT NULL, \"updated_at\" INTEGER NOT NULL, \"synced_at\" INTEGER NULL, PRIMARY KEY (\"id\"), CHECK (type IN ('debt', 'receivable')), CHECK (status IN ('paid', 'unpaid')), CHECK (length(trim(contact_name)) > 0), CHECK (amount > 0), CHECK (remaining_amount >= 0), CHECK (remaining_amount <= amount),         CHECK (\n          (status = 'paid' AND remaining_amount = 0)\n          OR\n          (status = 'unpaid' AND remaining_amount > 0)\n        )\n        ,         CHECK (\n          source_transaction_id IS NULL\n          OR type = 'receivable'\n        )\n        );"
        }
      ]
    },
